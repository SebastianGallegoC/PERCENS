# Copia a ".env" en la raíz del repositorio (junto a docker-compose.yml).

# Dominios públicos de Survey. Deben apuntar al mismo VPS que Traefik.
NO_SIGNAL_APP_DOMAIN=survey.nosignal.site
NO_SIGNAL_API_DOMAIN=api.survey.nosignal.site

# Let's Encrypt (lo usa la instancia Traefik compartida del host).
ACME_EMAIL=admin@nosignal.site

# Origen del SPA para CORS del backend.
CORS_ORIGINS=https://survey.nosignal.site

# Secretos independientes de Huertas.
ENVIRONMENT=production
JWT_SECRET=REEMPLAZAR_CON_SECRETO_SURVEY_LARGO_Y_ALEATORIO
JWT_EXPIRES_MINUTES=525600
POSTGRES_PASSWORD=REEMPLAZAR_PASSWORD_DB_SURVEY
NOSIGNAL_AUTH_USERS={"admin":"REEMPLAZAR_HASH_BCRYPT_SURVEY"}
ALLOW_INSECURE_DEFAULTS=false
AUTO_CREATE_SCHEMA=false

# URL absoluta del API embebida en el build del frontend Survey.
VITE_API_URL=https://api.survey.nosignal.site

# Opcional: solo si necesitás salirte de la DB local del compose de Survey.
# Por defecto el backend usa: postgresql+asyncpg://nosignal_survey:<POSTGRES_PASSWORD>@nosignal-survey-db:5432/nosignal_survey
# SURVEY_DATABASE_URL=postgresql+asyncpg://nosignal_survey:REEMPLAZAR_PASSWORD_DB_SURVEY@nosignal-survey-db:5432/nosignal_survey

